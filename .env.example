# --- Reasoning / LLM (used by agent runner scripts when wired) ---
GEMINI_API_KEY=
# Optional alternates
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Scout / web retrieval ---
FIRECRAWL_API_KEY=

# --- Local services ---
# FastAPI plugin backend (Next.js browser must reach this URL)
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# Dynamic plugin loading (run uvicorn from permanent_scaffold/backend_fastapi)
# If PLUGIN_FILE is unset and ../../3_core_logic_plugins/plugins/active/core_concept.py
# exists, the backend uses that file automatically. Override explicitly with:
PLUGIN_FILE=../../3_core_logic_plugins/plugins/active/core_concept.py
# To force the packaged scaffold plugin instead: set PLUGIN_FILE to
# permanent_scaffold/backend_fastapi/plugin/core_concept.py (from repo root), or
# remove/rename the active pipeline plugin, or use a dotted module path:
# PLUGIN_FILE=
# PLUGIN_MODULE=plugin.core_concept

# Reload plugin from disk on each /api/run (dev-friendly; set 0 in production)
PLUGIN_AUTO_RELOAD=1

# --- Integrations (optional) ---
GITHUB_TOKEN=
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
